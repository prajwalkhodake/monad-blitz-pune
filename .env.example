# ═══════════════════════════════════════════
#  Autonomous Bounty Verifier — Environment
# ═══════════════════════════════════════════

# 🔑 DEPLOYER — wallet that deploys the contract
# Get testnet MON from: https://faucet.monad.xyz
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key

# 🤖 AGENT — wallet that approves bounties (the AI agent)
AGENT_PRIVATE_KEY=0x_your_agent_private_key
AGENT_WALLET_ADDRESS=0x_your_agent_wallet_address

# 📜 CONTRACT — deployed BountyEscrow address
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_your_deployed_contract_address

# 🐙 GITHUB — personal access token with repo scope
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token

# 🧠 ANTHROPIC — Claude API key
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key

# ⛓️ MONAD TESTNET
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
