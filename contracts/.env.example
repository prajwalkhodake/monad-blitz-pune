# === DEPLOYER WALLET ===
# Private key for the wallet that deploys the contract.
# This wallet needs testnet MON from https://faucet.monad.xyz
# NEVER commit a real private key — this file is just a template.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# === AGENT WALLET ADDRESS ===
# The address of the AI agent's wallet. This wallet will be the ONLY one
# allowed to call approveBounty(). Set this BEFORE deploying.
AGENT_WALLET_ADDRESS=0xAGENT_WALLET_ADDRESS_HERE

# === MONAD TESTNET ===
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
